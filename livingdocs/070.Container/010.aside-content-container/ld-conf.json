{
  "name": "aside-content-container",
  "label": "Aside content container",
  "properties": ["sticky", "pdf-spacer"],
  "directives": {
    "aside": {
      "allowedChildren": ["paragraph", "link"]
    },
    "content": {
      "defaultComponents": {
        "paragraph": "paragraph"
      },
      "defaultContent": [
        {
          "component": "paragraph"
        }
      ]
    }
  }
}
